# ─── Copy this to .env and fill in your values ────────────────────────────────
# cp .env.example .env
# NEVER commit .env to git

# API Authentication
# Generate a key with: python scripts/generate_api_key.py
API_KEY=your-secret-key-here
REQUIRE_API_KEY=true

# Server
HOST=0.0.0.0
PORT=8000

# TTS Model: "vits" (200MB, fast) or "xtts" (2.5GB, multilingual voice cloning)
TTS_MODEL_TYPE=vits

# Device: "cpu" or "cuda"
DEVICE=cpu

# Custom models/data directory (override if on external storage)
# MODELS_DIR=/external/models
# DATA_DIR=/external/data

# Database
DATABASE_URL=sqlite:///emotion_voice.db

# HuggingFace cache
# HF_HOME=/home/user/.cache/huggingface

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5001
